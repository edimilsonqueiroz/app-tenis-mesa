# Environment Configuration
# Copy this file to .env and fill in the values for your environment

# =============================================================================
# DEVELOPMENT (SQLite - Default)
# =============================================================================
# ENVIRONMENT=development
# SECRET_KEY=your-dev-secret-key-here

# =============================================================================
# PRODUCTION (PostgreSQL - Required)
# =============================================================================
# Uncomment and fill these for production with PostgreSQL

# Environment
# ENVIRONMENT=production

# Security
# SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Database Configuration (PostgreSQL)
# DB_USER=postgres
# DB_PASSWORD=your-secure-password-here
# DB_HOST=your-database-host.example.com
# DB_PORT=5432
# DB_NAME=tenis_mesa

# =============================================================================
# NOTES
# =============================================================================
# - In development: SQLite is used by default (file-based, no setup needed)
# - In production: PostgreSQL is required (must set DB_PASSWORD and other vars)
# - SECRET_KEY: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - Never commit .env file to version control (add to .gitignore)
# - .env.example should be committed to help other developers setup their environment
